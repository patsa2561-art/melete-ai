{
  "name": "melete-ai",
  "version": "0.31.0",
  "description": "Melete — the Self-Driving Discovery Brain. A closed-loop active-experiment engine with a pluggable oracle and a signed, offline-verifiable discovery trace. Mneme remembers; Melete discovers.",
  "type": "module",
  "bin": {
    "melete": "bin/melete.mjs",
    "melete-server": "bin/melete-server.mjs"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE",
    "examples"
  ],
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run",
    "gauntlet": "node dist/cli/gauntlet.js",
    "bench": "node bin/melete.mjs bench",
    "prepublishOnly": "npm run build && npm run test"
  },
  "keywords": [
    "self-driving-lab",
    "discovery",
    "active-learning",
    "experiment-design",
    "optimization",
    "provenance",
    "signed",
    "reproducible",
    "resonance",
    "ai-agent",
    "oracle",
    "replication",
    "cross-agent"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
